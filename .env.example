# ================================================
# Git Recovery - Environment Configuration
# ================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ================================================

# GitHub App Configuration
# Create a GitHub App at: https://github.com/settings/apps/new
GITHUB_APP_ID=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Private Key: Choose ONE method
# ---
# Method A: File path (for local development)
GITHUB_APP_PRIVATE_KEY_PATH=your-app.private-key.pem
# Method B: Base64-encoded PEM content (for production / Vercel / Docker)
#   Generate with: cat your-key.pem | base64 -w 0
GITHUB_APP_PRIVATE_KEY=

# Database (PostgreSQL)
# Local: postgresql://postgres:postgres@localhost:5432/git_recovery
# Vercel Postgres / Neon / Supabase: use their connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/git_recovery?schema=public

# Session Secret (generate a random string, min 32 characters)
#   Generate with: openssl rand -hex 32
SESSION_SECRET=

# App URL (change to your production domain when deploying)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Optional: AI Commit Messages (any OpenAI-compatible API)
# Examples: OpenAI, DeepSeek, OpenRouter, local Ollama, etc.
AI_BASE_URL=
AI_API_KEY=
